{
  "name": "react-native-app-exit",
  "version": "1.0.3",
  "description": "Exit, close, and kill your React Native app with support for New Architecture",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index",
  "source": "src/index.tsx",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "typescript": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "prepare": "bob build",
    "release": "release-it"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "exit",
    "close",
    "kill",
    "shutdown",
    "quit",
    "terminate",
    "new-architecture",
    "turbo-module"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theocikos/react-native-app-exit.git"
  },
  "author": "Theocikos <theocikos@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/theocikos/react-native-app-exit/issues"
  },
  "homepage": "https://github.com/theocikos/react-native-app-exit#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@react-native/eslint-config": "^0.73.1",
    "@release-it/conventional-changelog": "^9.0.4",
    "@types/react": "^18.2.44",
    "@types/react-native": "^0.73.0",
    "eslint": "^8.51.0",
    "prettier": "^3.0.3",
    "react": "18.2.0",
    "react-native": "0.73.0",
    "react-native-builder-bob": "^0.23.2",
    "release-it": "^17.0.0",
    "typescript": "^5.2.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "codegenConfig": {
    "name": "RNAppExitSpec",
    "type": "modules",
    "jsSrcsDir": "src"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
